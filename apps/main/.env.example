NEXT_PUBLIC_SITE_URL=https://vavaw.vn

# Supabase connection (required for CMS_DATA_SOURCE=supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# CMS data source
# static = use @vavaw/brand-config (default, always safe for production)
# supabase = try Supabase public read first, fallback to static if error/empty
CMS_DATA_SOURCE=static

# Note: ISR revalidation interval (default 60s) is a static constant in
# apps/main/app/page.tsx. To change it, update the export const revalidate value
# and redeploy. Next.js does not support env-driven dynamic revalidate values.
