NEXT_PUBLIC_SITE_URL=https://vavaw.vn

# Supabase connection (required for CMS_DATA_SOURCE=supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# CMS data source
# static = use @vavaw/brand-config (default, always safe for production)
# supabase = try Supabase public read first, fallback to static if error/empty
CMS_DATA_SOURCE=static

# CMS Debug Badge (TEMPORARY — for local dev and CMS verification ONLY)
# Set to "true" ONLY when verifying hero CMS media is rendering correctly.
# Must be "false" or absent before production launch — never expose in production.
# NEXT_PUBLIC_SHOW_CMS_DEBUG=false

# Revalidation secret (Server only)
REVALIDATION_SECRET=

# Analytics Configuration
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_ANALYTICS_PROVIDER=console

# Email Notifications (Lead Capture)
EMAIL_PROVIDER=noop
RESEND_API_KEY=
LEAD_NOTIFICATION_TO=
LEAD_NOTIFICATION_FROM=
# Monitoring
NEXT_PUBLIC_MONITORING_ENABLED=false
NEXT_PUBLIC_MONITORING_PROVIDER=console
SENTRY_DSN=


SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=


# Signed Preview
CMS_PREVIEW_SECRET=
CMS_PREVIEW_TOKEN_TTL_SECONDS=900
SUPABASE_SERVICE_ROLE_KEY=

