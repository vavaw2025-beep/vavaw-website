NEXT_PUBLIC_SITE_URL=https://admin.vavaw.vn

# Supabase connection
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: DO NOT prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=
REVALIDATION_SECRET=

# Auth modes
ADMIN_AUTH_MODE=mock
NEXT_PUBLIC_ADMIN_AUTH_MODE=mock

# CMS Revalidation URLs
MAIN_REVALIDATE_URL=https://vavaw.vn/api/revalidate
BEAUTY_REVALIDATE_URL=https://beauty.vavaw.vn/api/revalidate
FRANCHISE_REVALIDATE_URL=https://franchise.vavaw.vn/api/revalidate
CMS_REVALIDATION_ENABLED=false

# Analytics Configuration
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_ANALYTICS_PROVIDER=console

# Email Notifications (Lead Capture)
EMAIL_PROVIDER=noop
RESEND_API_KEY=
LEAD_NOTIFICATION_TO=
LEAD_NOTIFICATION_FROM=
# Monitoring
NEXT_PUBLIC_MONITORING_ENABLED=false
NEXT_PUBLIC_MONITORING_PROVIDER=console
SENTRY_DSN=


SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=


# Required for automated admin invites (Admin App only)
# Prefer SUPABASE_SECRET_KEY. Fallback to SUPABASE_SERVICE_ROLE_KEY.
# Never expose these to the client.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Signed Preview
CMS_PREVIEW_SECRET=
CMS_PREVIEW_TOKEN_TTL_SECONDS=900
