NEXT_PUBLIC_SITE_URL=https://vavaw.vn
NEXT_PUBLIC_BEAUTY_URL=https://beauty.vavaw.vn
NEXT_PUBLIC_FRANCHISE_URL=https://franchise.vavaw.vn
NEXT_PUBLIC_ADMIN_URL=https://admin.vavaw.vn

# Supabase connection
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: DO NOT prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=
REVALIDATION_SECRET=

# Auth modes
ADMIN_AUTH_MODE=mock
NEXT_PUBLIC_ADMIN_AUTH_MODE=mock

# CMS data source for public apps (main, beauty, franchise)
# static = use @vavaw/brand-config (default, always safe for production)
# supabase = try Supabase first, fallback to static if error/empty
CMS_DATA_SOURCE=static

# CMS Revalidation URLs (Admin only)
MAIN_REVALIDATE_URL=https://vavaw.vn/api/revalidate
BEAUTY_REVALIDATE_URL=https://beauty.vavaw.vn/api/revalidate
FRANCHISE_REVALIDATE_URL=https://franchise.vavaw.vn/api/revalidate
CMS_REVALIDATION_ENABLED=false

# Analytics Configuration
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_ANALYTICS_PROVIDER=console
