# VAVAW Platform Environment Variables

# Public Apps Shared Configuration (apps/main, apps/beauty, apps/franchise)
NEXT_PUBLIC_SITE_URL=https://vavaw.vn
NEXT_PUBLIC_BEAUTY_URL=https://beauty.vavaw.vn
NEXT_PUBLIC_FRANCHISE_URL=https://franchise.vavaw.vn
NEXT_PUBLIC_ADMIN_URL=https://admin.vavaw.vn

# CMS Data Source ('static' for initial rollout, 'supabase' after production CMS verification)
CMS_DATA_SOURCE=static

# Supabase Public Configuration (Server & Client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Admin Secrets (SERVER-ONLY - ADMIN APP ONLY - NEVER USE NEXT_PUBLIC_)
# Prefer SUPABASE_SECRET_KEY, fallback to SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# CMS On-Demand Revalidation (SERVER-ONLY - DO NOT EXPOSE)
REVALIDATION_SECRET=your-revalidation-secret-here
CMS_REVALIDATION_ENABLED=true
MAIN_REVALIDATE_URL=https://vavaw.vn/api/revalidate
BEAUTY_REVALIDATE_URL=https://beauty.vavaw.vn/api/revalidate
FRANCHISE_REVALIDATE_URL=https://franchise.vavaw.vn/api/revalidate

# Signed Preview Mode (SERVER-ONLY - DO NOT EXPOSE)
CMS_PREVIEW_SECRET=your-cms-preview-secret-here
CMS_PREVIEW_TOKEN_TTL_SECONDS=900

# Admin Auth Mode ('supabase' required for production, 'mock' for local dev)
ADMIN_AUTH_MODE=supabase
NEXT_PUBLIC_ADMIN_AUTH_MODE=supabase

# Email Notification Provider ('resend' | 'console' | 'noop')
EMAIL_PROVIDER=noop
RESEND_API_KEY=
LEAD_NOTIFICATION_TO=
LEAD_NOTIFICATION_FROM=

# Monitoring & Error Reporting ('noop' | 'console' | 'sentry')
NEXT_PUBLIC_MONITORING_ENABLED=false
NEXT_PUBLIC_MONITORING_PROVIDER=console
SENTRY_DSN=
